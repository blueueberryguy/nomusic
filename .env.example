# Copy this file to .env and fill in your credentials.
# .env is gitignored — never commit real keys.

# ── Firefox (AMO) signing ──────────────────────────────────────────────────────
# Generate at: https://addons.mozilla.org/developers/addon/api/key/
AMO_JWT_ISSUER=user:12345678:123
AMO_JWT_SECRET=your_amo_api_secret_here

# ── Chrome Web Store publishing ────────────────────────────────────────────────
# Extension ID from: https://chrome.google.com/webstore/devconsole
CHROME_EXTENSION_ID=your_extension_id_here

# OAuth2 credentials from: https://console.cloud.google.com
# Scope needed: https://www.googleapis.com/auth/chromewebstore
# Setup guide: https://developer.chrome.com/docs/webstore/using-api#beforeyoubegin
CHROME_CLIENT_ID=your_client_id.apps.googleusercontent.com
CHROME_CLIENT_SECRET=your_client_secret_here
CHROME_REFRESH_TOKEN=your_refresh_token_here
